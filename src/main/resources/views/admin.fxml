<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import java.net.URL?>

<BorderPane xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.AdminController"
            style="-fx-background-color: #f5f5f5;">

    <!-- ✅ ПРАВИЛЬНОЕ ПОДКЛЮЧЕНИЕ CSS СТИЛЕЙ -->
    <stylesheets>
        <URL value="@styles/styles.css"/>
    </stylesheets>

    <!-- HEADER -->
    <top>
        <VBox style="-fx-background-color: #ffffff; -fx-border-color: #e5e7eb; -fx-border-width: 0 0 1 0;">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20"/>
            </padding>
            <HBox spacing="15" alignment="CENTER_LEFT">
                <Label text="Панель администратора" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1f2937;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="exitAdminBtn" text="← Выход из панели" styleClass="button-danger"/>
            </HBox>
        </VBox>
    </top>

    <!-- MAIN CONTENT -->
    <center>
        <TabPane fx:id="adminTabs" tabClosingPolicy="UNAVAILABLE"
                 style="-fx-background-color: #ffffff;">

            <!-- ============ ВКЛ. ТОВАРЫ ============ -->
            <Tab text="📦 Товары" closable="false">
                <VBox spacing="15" style="-fx-background-color: #ffffff;">
                    <padding>
                        <Insets top="20" right="20" bottom="20" left="20"/>
                    </padding>

                    <!-- Заголовок и кнопки -->
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Управление товарами" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1f2937;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button fx:id="addProductBtn" text="➕ Добавить товар" styleClass="button-success"/>
                    </HBox>

                    <Separator/>

                    <!-- Таблица товаров -->
                    <TableView fx:id="productsTable" styleClass="table-view" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn text="ID" prefWidth="60"/>
                            <TableColumn text="Название" prefWidth="250"/>
                            <TableColumn text="Категория" prefWidth="150"/>
                            <TableColumn text="Цена (₽)" prefWidth="100"/>
                            <TableColumn text="Склад" prefWidth="80"/>
                            <TableColumn text="Действия" prefWidth="150"/>
                        </columns>
                    </TableView>
                </VBox>
            </Tab>

            <!-- ============ ВКЛ. ПОЛЬЗОВАТЕЛИ ============ -->
            <Tab text="👥 Пользователи" closable="false">
                <VBox spacing="15" style="-fx-background-color: #ffffff;">
                    <padding>
                        <Insets top="20" right="20" bottom="20" left="20"/>
                    </padding>

                    <!-- Заголовок и поиск -->
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Управление пользователями" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1f2937;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <TextField fx:id="userSearchField" promptText="🔍 Поиск по Email, Имени или Фамилии..." prefWidth="300"/>
                    </HBox>

                    <Separator/>

                    <!-- Таблица пользователей -->
                    <TableView fx:id="usersTable" styleClass="table-view" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn text="Email" prefWidth="250"/>
                            <TableColumn text="Имя" prefWidth="150"/>
                            <TableColumn text="Фамилия" prefWidth="150"/>
                            <TableColumn text="Статус" prefWidth="150"/>
                            <TableColumn text="Действия" prefWidth="150"/>
                        </columns>
                    </TableView>
                </VBox>
            </Tab>

            <!-- ============ ВКЛ. ЗАКАЗЫ ============ -->
            <Tab text="📋 Заказы" closable="false">
                <VBox spacing="15" style="-fx-background-color: #ffffff;">
                    <padding>
                        <Insets top="20" right="20" bottom="20" left="20"/>
                    </padding>

                    <!-- Фильтры -->
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="История заказов" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1f2937;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label text="Статус:" style="-fx-font-size: 12px;"/>
                        <ComboBox fx:id="orderStatusFilter" prefWidth="150"/>
                    </HBox>

                    <Separator/>

                    <!-- Таблица заказов -->
                    <TableView fx:id="ordersTable" styleClass="table-view" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn text="ID" prefWidth="80"/>
                            <TableColumn text="Email" prefWidth="200"/>
                            <TableColumn text="Сумма (₽)" prefWidth="120"/>
                            <TableColumn text="Статус" prefWidth="120"/>
                            <TableColumn text="Дата" prefWidth="150"/>
                            <TableColumn text="Действия" prefWidth="150"/>
                        </columns>
                    </TableView>
                </VBox>
            </Tab>

            <!-- ============ ВКЛ. ПРОМОКОДЫ ============ -->
            <Tab text="🎟 Промокоды" closable="false">
                <VBox spacing="15" style="-fx-background-color: #ffffff;">
                    <padding>
                        <Insets top="20" right="20" bottom="20" left="20"/>
                    </padding>

                    <!-- Заголовок и кнопки -->
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Управление промокодами" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: #1f2937;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button fx:id="addPromoCodeBtn" text="➕ Создать промокод" styleClass="button-success"/>
                    </HBox>

                    <Separator/>

                    <!-- Таблица промокодов -->
                    <TableView fx:id="promoCodesTable" styleClass="table-view" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn text="ID" prefWidth="50"/>
                            <TableColumn text="Код" prefWidth="150"/>
                            <TableColumn text="Скидка %" prefWidth="100"/>
                            <TableColumn text="Лимит" prefWidth="80"/>
                            <TableColumn text="Использовано" prefWidth="120"/>
                            <TableColumn text="Срок действия" prefWidth="120"/>
                            <TableColumn text="Статус" prefWidth="100"/>
                            <TableColumn text="Действия" prefWidth="100"/>
                        </columns>
                        <placeholder>
                            <Label text="Нет промокодов" style="-fx-text-fill: #9ca3af;"/>
                        </placeholder>
                    </TableView>
                </VBox>
            </Tab>
        </TabPane>
    </center>
</BorderPane>
