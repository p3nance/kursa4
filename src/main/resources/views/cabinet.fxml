<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<BorderPane fx:id="rootBorderPane"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="controllers.CabinetController"
            stylesheets="@styles/styles.css"
            styleClass="cab-root">

    <!-- ═══════════════════════════════════════════
         ШАП КА: градиент + аватар + email + кнопки
         ═══════════════════════════════════════════ -->
    <top>
        <VBox styleClass="cab-header">
            <!-- Эта HBox — именно сюда checkIfAdmin() добавляет кнопку «Админ панель» -->
            <HBox spacing="14" alignment="CENTER_LEFT" styleClass="cab-header-inner">

                <!-- Аватар-заглушка -->
                <StackPane styleClass="cab-avatar">
                    <Label text="👤" style="-fx-font-size: 22px;"/>
                </StackPane>

                <!-- Заголовок + email -->
                <VBox spacing="3">
                    <Label text="Личный кабинет" styleClass="cab-header-title"/>
                    <Label fx:id="userEmailLabel" text="Загрузка…" styleClass="cab-header-email"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- Кнопки (admin-кнопка будет добавлена сюда же) -->
                <Button fx:id="backButton"  text="← Назад"  styleClass="cab-btn-back"/>
                <Button fx:id="logoutButton" text="Выход →" styleClass="cab-btn-logout"/>
            </HBox>
        </VBox>
    </top>

    <!-- ═══════════════════════════════════════════
         КОНТЕНТ
         ═══════════════════════════════════════════ -->
    <center>
        <ScrollPane fx:id="scrollPane" fitToWidth="true" styleClass="cab-scroll">

            <VBox fx:id="mainContentVBox" styleClass="cab-content" spacing="20">

                <!-- ───────────────────────────────────────────
                     КАРТОЧКА: Мой профиль
                     ─────────────────────────────────────────── -->
                <VBox spacing="18" styleClass="cab-card">

                    <!-- Заголовок секции -->
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="✏️" style="-fx-font-size: 18px;"/>
                        <Label text="Мой профиль" styleClass="cab-section-title"/>
                    </HBox>
                    <Separator styleClass="cab-sep"/>

                    <!-- Сетка полей -->
                    <GridPane hgap="16" vgap="14">
                        <columnConstraints>
                            <ColumnConstraints minWidth="100" prefWidth="115"/>
                            <ColumnConstraints hgrow="ALWAYS" minWidth="140"/>
                            <ColumnConstraints minWidth="100" prefWidth="115"/>
                            <ColumnConstraints hgrow="ALWAYS" minWidth="140"/>
                        </columnConstraints>

                        <!-- Строка 0 -->
                        <Label text="📧 Email"
                               GridPane.columnIndex="0" GridPane.rowIndex="0"
                               GridPane.valignment="CENTER"
                               styleClass="cab-field-label"/>
                        <TextField fx:id="emailField" editable="false"
                                   promptText="email@example.com"
                                   GridPane.columnIndex="1" GridPane.rowIndex="0"
                                   styleClass="cab-field-readonly"/>

                        <Label text="👤 Имя"
                               GridPane.columnIndex="2" GridPane.rowIndex="0"
                               GridPane.valignment="CENTER"
                               styleClass="cab-field-label"/>
                        <TextField fx:id="nameField"
                                   promptText="Введите имя"
                                   GridPane.columnIndex="3" GridPane.rowIndex="0"/>

                        <!-- Строка 1 -->
                        <Label text="👨 Фамилия"
                               GridPane.columnIndex="0" GridPane.rowIndex="1"
                               GridPane.valignment="CENTER"
                               styleClass="cab-field-label"/>
                        <TextField fx:id="surnameField"
                                   promptText="Введите фамилию"
                                   GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                        <Label text="☎ Телефон"
                               GridPane.columnIndex="2" GridPane.rowIndex="1"
                               GridPane.valignment="CENTER"
                               styleClass="cab-field-label"/>
                        <TextField fx:id="phoneField"
                                   promptText="+7 (000) 000-00-00"
                                   GridPane.columnIndex="3" GridPane.rowIndex="1"/>

                        <!-- Строка 2 -->
                        <Label text="🏙 Город"
                               GridPane.columnIndex="0" GridPane.rowIndex="2"
                               GridPane.valignment="CENTER"
                               styleClass="cab-field-label"/>
                        <TextField fx:id="cityField"
                                   promptText="Ваш город"
                                   GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                        <Label text="🏠 Адрес"
                               GridPane.columnIndex="2" GridPane.rowIndex="2"
                               GridPane.valignment="CENTER"
                               styleClass="cab-field-label"/>
                        <TextField fx:id="addressField"
                                   promptText="Улица, дом, квартира"
                                   GridPane.columnIndex="3" GridPane.rowIndex="2"/>
                    </GridPane>

                    <!-- Кнопка сохранения -->
                    <HBox>
                        <Button fx:id="saveButton"
                                text="💾  Сохранить изменения"
                                styleClass="cab-btn-save"
                                minWidth="220"/>
                    </HBox>
                </VBox>

                <!-- ───────────────────────────────────────────
                     КАРТОЧКА: Безопасность
                     ─────────────────────────────────────────── -->
                <VBox spacing="18" styleClass="cab-card">
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="🔐" style="-fx-font-size: 18px;"/>
                        <Label text="Безопасность" styleClass="cab-section-title"/>
                    </HBox>
                    <Separator styleClass="cab-sep"/>

                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <Button fx:id="changePasswordButton"
                                text="🔑  Изменить пароль"
                                styleClass="cab-btn-password"
                                minWidth="200"/>
                    </HBox>
                </VBox>

                <!-- ───────────────────────────────────────────
                     История заказов добавляется динамически
                     через loadOrderHistory() в контроллере
                     ─────────────────────────────────────────── -->

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>