<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.geometry.Insets?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      styleClass="product-card"
      spacing="8"
      alignment="TOP_CENTER"
      prefWidth="220"
      minHeight="260">

    <!-- Изображение -->
    <ImageView fx:id="productImage"
               fitWidth="180" fitHeight="110"
               preserveRatio="true"/>

    <!-- Название -->
    <Label fx:id="productName"
           text="Название товара"
           styleClass="product-card-title"
           wrapText="true"
           prefHeight="40" minHeight="40"/>

    <!-- Производитель -->
    <Label fx:id="productManufacturer"
           text="Производитель"
           styleClass="product-card-manufacturer"
           prefHeight="20" minHeight="20"/>

    <!-- Цена -->
    <Label fx:id="productPrice"
           text="0 ₽"
           styleClass="product-card-price"
           prefHeight="24" minHeight="24"/>

    <!-- Распорка -->
    <Region VBox.vgrow="ALWAYS"/>

    <!-- Кнопки -->
    <HBox spacing="5" alignment="CENTER" prefHeight="35" minHeight="35">
        <Button fx:id="detailsButton"
                text="Подробнее"
                styleClass="product-card-more-btn"
                HBox.hgrow="ALWAYS"
                maxWidth="Infinity"/>
        <Button fx:id="addToCartButton"
                text="🛒"
                styleClass="product-card-cart-btn"/>
    </HBox>

</VBox>
