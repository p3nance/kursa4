<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            stylesheets="@../styles/styles.css"
            style="-fx-background-color: #f5f5f5;">

    <!-- Шапка с кнопкой назад -->
    <top>
        <VBox styleClass="detail-header">
            <Button fx:id="backButton"
                    text="← Назад к товарам"
                    styleClass="detail-back-btn"/>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" styleClass="detail-scroll">
            <VBox spacing="24" styleClass="detail-content">

                <!-- Основной блок: изображение + инфо -->
                <HBox spacing="32" styleClass="detail-card">

                    <!-- Изображение слева -->
                    <VBox alignment="TOP_CENTER" spacing="10" minWidth="400">
                        <ImageView fx:id="largeImage"
                                   fitWidth="400" fitHeight="300"
                                   preserveRatio="true"/>
                    </VBox>

                    <!-- Информация справа -->
                    <VBox spacing="14" HBox.hgrow="ALWAYS">

                        <Label fx:id="productNameLabel"
                               text="Название товара"
                               styleClass="detail-product-name"
                               wrapText="true"/>

                        <Label fx:id="manufacturerLabel"
                               text="Производитель:"
                               styleClass="detail-meta"/>

                        <Label fx:id="categoryLabel"
                               text="Категория:"
                               styleClass="detail-meta"/>

                        <Label fx:id="priceLabel"
                               text="0 ₽"
                               styleClass="detail-price"/>

                        <Separator/>

                        <Label text="Описание:"
                               styleClass="detail-section-title"/>

                        <TextArea fx:id="descriptionArea"
                                  wrapText="true"
                                  editable="false"
                                  prefRowCount="6"
                                  styleClass="detail-description"/>

                        <Separator/>

                        <!-- Кнопки действий -->
                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Button fx:id="addToCartButton"
                                    text="🛒 Добавить в корзину"
                                    styleClass="detail-cart-btn"
                                    prefWidth="210"/>
                            <Button fx:id="buyNowButton"
                                    text="💳 Купить сейчас"
                                    styleClass="detail-buy-btn"
                                    prefWidth="210"/>
                        </HBox>

                    </VBox>
                </HBox>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
